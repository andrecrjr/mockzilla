{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Mockzilla",
	"version": "1.0.1",
	"identifier": "dev.mockzilla.app",
	"build": {
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "bun run desktop:stage",
		"devUrl": "http://localhost:36666",
		"frontendDist": "../desktop-dist/empty"
	},
	"app": {
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis", "dmg", "appimage", "deb"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico",
			"icons/icon.png"
		],
		"externalBin": ["binaries/mockzilla-node"],
		"resources": {
			"../desktop-dist/server": "desktop-server"
		}
	}
}
